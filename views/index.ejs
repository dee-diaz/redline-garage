<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head.ejs") %>
<body>

  <%- include("partials/header.ejs") %>

  <main>
    <%- include("partials/errors.ejs") %>
    <div class="page-container">
      <div class="listing-toolbar">
        <h1 class="listing-toolbar-title">featured products</h1>
      </div>

      <div class="listing-grid">
        <% if(featuredProducts.length > 0) { %>
          <% featuredProducts.forEach(function(product) { %>
            <article class="record-card">
              <% if (product.stock < 3 && product.stock > 0) { %>
                <span class="record-card-badge record-card-badge--low-stock">low stock</span>
              <% } %>
              <% if (product.stock === 0) { %>
                <span class="record-card-badge record-card-badge--no-stock">out of stock</span>
              <% } %>
              <div class="record-card-image">
                <img src="<%= product.image %>" alt="">
              </div>
              <div class="record-card-meta">
                <div class="record-card-info">
                  <p class="record-card-category"><%= product.category %></p>
                  <h3 class="record-card-title"><%= product.name %></h3>
                  <p class="record-card-subtitle"><%= product.brand %></p>
                  <p class="record-card-price"><%= product.price %></p>
                </div>
              </div>
            </article>
          <% }) %>
        <% } else { %>
          <p class="empty-state">couldn't load products right now</p>
        <% } %>
      </div>

      <div class="listing-footer">
        <button type="button" class="btn-see-all">see all</button>
      </div>
    </div>
  </main>

  <%- include("partials/footer.ejs") %>

</body>
</html>
