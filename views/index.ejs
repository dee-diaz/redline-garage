<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("partials/head.ejs") %>
</head>
<body>

  <header class="navbar">
    <div class="navbar-inner">
      <button type="button" class="nav-menu-btn" aria-label="Menu">
        <svg class="icon" viewBox="0 0 24 24"><line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/></svg>
      </button>
      <a href="/" class="logo">redline garage</a>
      <%- include("partials/nav.ejs") %>
      <div class="nav-utility">
        <button type="button" class="nav-icon-btn" aria-label="Search">
          <svg class="icon" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </button>
        <button type="button" class="nav-icon-btn" aria-label="Favorites">
          <svg class="icon" viewBox="0 0 24 24"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"/></svg>
        </button>
      </div>
    </div>
  </header>

  <main>
    <%- include("partials/errors.ejs") %>
    <div class="page-container">
      <div class="listing-toolbar">
        <h2 class="listing-toolbar-title">featured products</h2>
      </div>

      <div class="listing-grid">
        <% if(featuredProducts.length > 0) { %>
          <% featuredProducts.forEach(function(product) { %>
            <article class="record-card">
              <% if (product.stock < 3 && product.stock > 0) { %>
                <span class="record-card-badge record-card-badge--low-stock">low stock</span>
              <% } %>
              <% if (product.stock === 0) { %>
                <span class="record-card-badge record-card-badge--no-stock">out of stock</span>
              <% } %>
              <div class="record-card-image">
                <img src="<%= product.image %>" alt="">
              </div>
              <div class="record-card-meta">
                <div class="record-card-info">
                  <p class="record-card-category"><%= product.category %></p>
                  <h3 class="record-card-title"><%= product.name %></h3>
                  <p class="record-card-subtitle"><%= product.brand %></p>
                  <p class="record-card-price"><%= product.price %></p>
                </div>
              </div>
            </article>
          <% }) %>
        <% } else { %>
          <p class="empty-state">couldn't load products right now</p>
        <% } %>
      </div>

      <div class="listing-footer">
        <button type="button" class="btn-see-all">see all</button>
      </div>
    </div>
  </main>

  <%- include("partials/footer.ejs") %>

</body>
</html>
