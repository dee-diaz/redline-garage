<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Redline Garage</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

  <header class="navbar">
    <div class="navbar-inner">
      <button type="button" class="nav-menu-btn" aria-label="Menu">
        <svg class="icon" viewBox="0 0 24 24"><line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/></svg>
      </button>
      <a href="/" class="logo">redline garage</a>
      <ul class="nav-links">
        <li><a href="/">home</a></li>
        <li><a href="/vehicles">vehicles</a></li>
        <li><a href="/customers">customers</a></li>
        <li><a href="/services">services</a></li>
      </ul>
      <div class="nav-utility">
        <button type="button" class="nav-icon-btn" aria-label="Search">
          <svg class="icon" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </button>
        <a href="#" class="nav-account-link">account</a>
        <button type="button" class="nav-icon-btn" aria-label="Favorites">
          <svg class="icon" viewBox="0 0 24 24"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"/></svg>
        </button>
      </div>
    </div>
  </header>

  <main>
    <div class="page-container">
      <div class="listing-toolbar">
        <h2 class="listing-toolbar-title">records</h2>
        <div class="listing-toolbar-actions">
          <button type="button" class="carousel-arrow" aria-label="Previous">
            <svg class="icon" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button type="button" class="carousel-arrow" aria-label="Next">
            <svg class="icon" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      </div>

      <div class="listing-grid">
        <article class="record-card">
          <div class="record-card-image"></div>
          <div class="record-card-meta">
            <div class="record-card-thumb"></div>
            <div class="record-card-info">
              <h3 class="record-card-title">record title</h3>
              <p class="record-card-subtitle">by category</p>
              <p class="record-card-price">$0.00</p>
            </div>
          </div>
        </article>

        <article class="record-card">
          <span class="record-card-badge record-card-badge--new">new in</span>
          <div class="record-card-image"></div>
          <div class="record-card-meta">
            <div class="record-card-thumb"></div>
            <div class="record-card-info">
              <h3 class="record-card-title">record title</h3>
              <p class="record-card-subtitle">by category</p>
              <p class="record-card-price">$0.00</p>
            </div>
          </div>
        </article>

        <article class="record-card">
          <div class="record-card-image"></div>
          <div class="record-card-meta">
            <div class="record-card-thumb"></div>
            <div class="record-card-info">
              <h3 class="record-card-title">record title</h3>
              <p class="record-card-subtitle">by category</p>
              <p class="record-card-price">$0.00</p>
            </div>
          </div>
        </article>

        <article class="record-card">
          <span class="record-card-badge record-card-badge--sold-out">sold out</span>
          <div class="record-card-image"></div>
          <div class="record-card-meta">
            <div class="record-card-thumb"></div>
            <div class="record-card-info">
              <h3 class="record-card-title">record title</h3>
              <p class="record-card-subtitle">by category</p>
              <p class="record-card-price">$0.00</p>
            </div>
          </div>
        </article>

        <article class="record-card">
          <span class="record-card-badge record-card-badge--new-color">new color</span>
          <div class="record-card-image"></div>
          <div class="record-card-meta">
            <div class="record-card-thumb"></div>
            <div class="record-card-info">
              <h3 class="record-card-title">record title</h3>
              <p class="record-card-subtitle">by category</p>
              <p class="record-card-price">$0.00</p>
            </div>
          </div>
        </article>

        <article class="record-card">
          <div class="record-card-image"></div>
          <div class="record-card-meta">
            <div class="record-card-thumb"></div>
            <div class="record-card-info">
              <h3 class="record-card-title">record title</h3>
              <p class="record-card-subtitle">by category</p>
              <p class="record-card-price">$0.00</p>
            </div>
          </div>
        </article>

        <article class="record-card">
          <div class="record-card-image"></div>
          <div class="record-card-meta">
            <div class="record-card-thumb"></div>
            <div class="record-card-info">
              <h3 class="record-card-title">record title</h3>
              <p class="record-card-subtitle">by category</p>
              <p class="record-card-price">$0.00</p>
            </div>
          </div>
        </article>

        <article class="record-card">
          <div class="record-card-image"></div>
          <div class="record-card-meta">
            <div class="record-card-thumb"></div>
            <div class="record-card-info">
              <h3 class="record-card-title">record title</h3>
              <p class="record-card-subtitle">by category</p>
              <p class="record-card-price">$0.00</p>
            </div>
          </div>
        </article>
      </div>

      <div class="listing-footer">
        <button type="button" class="btn-see-all">see all</button>
      </div>
    </div>
  </main>

  <footer class="site-footer">
    <div class="page-container footer-inner">
      <ul class="footer-links">
        <li><a href="/">home</a></li>
        <li><a href="/vehicles">vehicles</a></li>
        <li><a href="/customers">customers</a></li>
        <li><a href="/services">services</a></li>
        <li><a href="/contact">contact</a></li>
      </ul>
      <span class="footer-copyright">&copy; redline garage</span>
    </div>
  </footer>

</body>
</html>
